PROMPT_RAG_SOURCE_PATH=/opt/prompt-rag/data/prompts.jsonl
PROMPT_RAG_DB_PATH=/opt/prompt-rag/data/prompt_rag.db
PROMPT_RAG_AUTO_INGEST=false

PROMPT_RAG_EMBEDDING_PROVIDER=openai-compatible
PROMPT_RAG_EMBEDDING_MODEL=text-embedding-v4
PROMPT_RAG_EMBEDDING_DIMENSIONS=1024
PROMPT_RAG_EMBEDDING_BATCH_SIZE=10
PROMPT_RAG_EMBEDDING_TEXT_MAX_CHARS=6000
PROMPT_RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PROMPT_RAG_EMBEDDING_API_KEY=CHANGE_ME

# Production uses the standard LLM settings instead of a local Windows config file.
PROMPT_RAG_TRANSLATION_PROVIDER=llm
PROMPT_RAG_LLM_BASE_URL=https://api.xiaomimimo.com/v1
PROMPT_RAG_LLM_API_KEY=CHANGE_ME
PROMPT_RAG_LLM_MODEL=mimo-v2.5

PROMPT_RAG_HOST=127.0.0.1
PROMPT_RAG_PORT=8010
PROMPT_RAG_CORS_ORIGINS=https://rag.example.com
PROMPT_RAG_LEGACY_FRONTEND_PATH=/opt/prompt-rag/web/index.html
PROMPT_RAG_LEGACY_STATIC_DIR=/opt/prompt-rag/web/static
PROMPT_RAG_STUDIO_DIST_DIR=/opt/prompt-rag/web-v2/dist

PROMPT_RAG_LEXICAL_WEIGHT=0.60
PROMPT_RAG_DENSE_WEIGHT=0.40
PROMPT_RAG_RRF_K=60
