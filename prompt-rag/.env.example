PROMPT_RAG_SOURCE_PATH=../knowledge-base/normalized/prompts.jsonl
PROMPT_RAG_DB_PATH=./data/prompt_rag.db
PROMPT_RAG_AUTO_INGEST=true

# none | sentence-transformers | openai-compatible
PROMPT_RAG_EMBEDDING_PROVIDER=none
PROMPT_RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small
PROMPT_RAG_EMBEDDING_DIMENSIONS=1024
PROMPT_RAG_EMBEDDING_BATCH_SIZE=10
PROMPT_RAG_EMBEDDING_TEXT_MAX_CHARS=6000
PROMPT_RAG_MODEL_CACHE_DIR=./data/models
PROMPT_RAG_EMBEDDING_BASE_URL=
PROMPT_RAG_EMBEDDING_API_KEY=

# Chinese response translation. "mimo" reads the existing provider config below.
PROMPT_RAG_TRANSLATION_PROVIDER=mimo
PROMPT_RAG_MIMO_CONFIG_PATH=D:/mycode/LangChain/rag_system/config/llm_config.json

# Optional OpenAI-compatible chat model for recommendation explanations/remixing.
PROMPT_RAG_LLM_BASE_URL=
PROMPT_RAG_LLM_API_KEY=
PROMPT_RAG_LLM_MODEL=

# Knowledge-base management center. Use long random values in production.
PROMPT_RAG_ADMIN_PASSWORD=
PROMPT_RAG_ADMIN_SESSION_SECRET=
PROMPT_RAG_ADMIN_SESSION_HOURS=12

PROMPT_RAG_HOST=127.0.0.1
PROMPT_RAG_PORT=8010
PROMPT_RAG_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Temporary legacy UI adapter. The original file is served read-only.
PROMPT_RAG_LEGACY_FRONTEND_PATH=./web/index.html
PROMPT_RAG_LEGACY_STATIC_DIR=./web/static
